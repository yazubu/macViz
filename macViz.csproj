<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="libbass" Version="2.4.18.3" />
    <PackageReference Include="ManagedBass" Version="4.0.2" />
    <PackageReference Include="OneWare.OpenCvSharp4.runtime.osx-arm64" Version="4.13.0.18" />
    <PackageReference Include="OpenCvSharp4" Version="4.13.0.20260602" />
    <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.13.0.20260602" />
    <PackageReference Include="OpenTK" Version="4.9.4" />
    <PackageReference Include="Twizzle.ImGui-Bundle.NET" Version="1.91.5.2" />
  </ItemGroup>

  <ItemGroup>
    <None Include="native/libabl_link.dylib" CopyToOutputDirectory="PreserveNewest" TargetPath="libabl_link.dylib" />
    <None Include="native/libabl_link.dll" CopyToOutputDirectory="PreserveNewest" TargetPath="libabl_link.dll" />
  </ItemGroup>

</Project>
